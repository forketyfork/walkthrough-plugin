<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>com.forketyfork.walkthrough</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>Walkthrough</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://github.com/forketyfork/walkthrough-plugin">forketyfork</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        <p>Walkthrough is an IntelliJ IDEA plugin for showing inline guided walkthroughs anchored to specific lines of code. It renders a styled popup near a target line, keeps a connector pointing at that line, and lets the reader step through a sequence of walkthrough items. Typical uses include codebase tours, onboarding new contributors, and AI-driven code explanations.</p>
        <p>The plugin also exposes a <code>show_walkthrough_items</code> MCP tool so LLM-driven agents can drive walkthroughs programmatically. The popup UI is built with JetBrains Compose (Jewel) and supports Markdown content, optional file and line navigation, and previous/next step navigation.</p>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <dependencies>
        <plugin id="com.intellij.modules.compose"/>
        <plugin id="com.intellij.mcpServer"/>
        <module name="intellij.platform.compose.markdown"/>
    </dependencies>

    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij.mcpServer">
        <mcpToolset implementation="com.forketyfork.walkthrough.ShowWalkthroughItemsToolset"/>
    </extensions>

    <actions resource-bundle="messages.WalkthroughBundle">
        <action id="com.forketyfork.walkthrough.ShowWalkthroughItemAction"
                class="com.forketyfork.walkthrough.ShowWalkthroughItemAction">
            <keyboard-shortcut keymap="$default" first-keystroke="control shift X"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
